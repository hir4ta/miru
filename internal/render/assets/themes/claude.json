{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#f0eee6",
    "margin": 2
  },
  "block_quote": {
    "color": "#a89684",
    "italic": true,
    "indent": 1,
    "indent_token": "> "
  },
  "paragraph": {},
  "list": {
    "color": "#f0eee6",
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#d97757",
    "bold": true
  },
  "h1": { "prefix": "# " },
  "h2": { "prefix": "## " },
  "h3": { "prefix": "### " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "color": "#786e59", "crossed_out": true },
  "emph": { "color": "#e2b04e", "italic": true },
  "strong": { "color": "#be5a37", "bold": true },
  "hr": { "color": "#5d544b", "format": "\n──────\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". ", "color": "#e2b04e" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#d97757", "underline": true },
  "link_text": { "color": "#e2b04e" },
  "image": { "color": "#d97757", "underline": true },
  "image_text": { "color": "#e2b04e", "format": "Image: {{.text}} →" },
  "code": { "color": "#c9b896" },
  "code_block": {
    "color": "#c9b896",
    "margin": 2,
    "chroma": {
      "text": { "color": "#f0eee6" },
      "error": { "color": "#f0eee6", "background_color": "#be5a37" },
      "comment": { "color": "#786e59", "italic": true },
      "comment_preproc": { "color": "#c79088" },
      "keyword": { "color": "#d97757" },
      "keyword_reserved": { "color": "#d97757" },
      "keyword_namespace": { "color": "#c79088" },
      "keyword_type": { "color": "#e2b04e" },
      "operator": { "color": "#c9744a" },
      "punctuation": { "color": "#a89684" },
      "name": { "color": "#f0eee6" },
      "name_builtin": { "color": "#e2b04e" },
      "name_tag": { "color": "#c79088" },
      "name_attribute": { "color": "#8a9a5b" },
      "name_class": { "color": "#e2b04e" },
      "name_constant": { "color": "#be5a37" },
      "name_decorator": { "color": "#c79088" },
      "name_exception": { "color": "#be5a37" },
      "name_function": { "color": "#d4a574" },
      "name_other": { "color": "#f0eee6" },
      "literal": { "color": "#c79088" },
      "literal_number": { "color": "#c79088" },
      "literal_date": { "color": "#a8c279" },
      "literal_string": { "color": "#a8c279" },
      "literal_string_escape": { "color": "#d97757" },
      "generic_deleted": { "color": "#be5a37" },
      "generic_emph": { "color": "#e2b04e", "italic": true },
      "generic_inserted": { "color": "#a8c279" },
      "generic_strong": { "color": "#d97757", "bold": true },
      "generic_subheading": { "color": "#c79088" },
      "background": { "background_color": "#1f1e1d" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n→ " },
  "html_block": {},
  "html_span": {}
}
