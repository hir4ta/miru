{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#ebdbb2",
    "margin": 2
  },
  "block_quote": {
    "color": "#928374",
    "italic": true,
    "indent": 1,
    "indent_token": "> "
  },
  "paragraph": {},
  "list": { "color": "#ebdbb2", "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#fabd2f", "bold": true },
  "h1": { "prefix": "# " },
  "h2": { "prefix": "## " },
  "h3": { "prefix": "### " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "color": "#928374", "crossed_out": true },
  "emph": { "color": "#b8bb26", "italic": true },
  "strong": { "color": "#fb4934", "bold": true },
  "hr": { "color": "#665c54", "format": "\n──────\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". ", "color": "#d3869b" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#83a598", "underline": true },
  "link_text": { "color": "#fb4934" },
  "image": { "color": "#83a598", "underline": true },
  "image_text": { "color": "#fb4934", "format": "Image: {{.text}} →" },
  "code": { "color": "#b8bb26" },
  "code_block": {
    "color": "#b8bb26",
    "margin": 2,
    "chroma": {
      "text": { "color": "#ebdbb2" },
      "error": { "color": "#ebdbb2", "background_color": "#fb4934" },
      "comment": { "color": "#928374", "italic": true },
      "comment_preproc": { "color": "#fb4934" },
      "keyword": { "color": "#fb4934" },
      "keyword_reserved": { "color": "#fb4934" },
      "keyword_namespace": { "color": "#fb4934" },
      "keyword_type": { "color": "#fabd2f" },
      "operator": { "color": "#fb4934" },
      "punctuation": { "color": "#ebdbb2" },
      "name": { "color": "#83a598" },
      "name_builtin": { "color": "#fabd2f" },
      "name_tag": { "color": "#fb4934" },
      "name_attribute": { "color": "#b8bb26" },
      "name_class": { "color": "#fabd2f" },
      "name_constant": { "color": "#d3869b" },
      "name_decorator": { "color": "#b8bb26" },
      "name_exception": { "color": "#fb4934" },
      "name_function": { "color": "#b8bb26" },
      "literal_number": { "color": "#d3869b" },
      "literal_string": { "color": "#b8bb26" },
      "literal_string_escape": { "color": "#fb4934" },
      "generic_deleted": { "color": "#fb4934" },
      "generic_emph": { "color": "#b8bb26", "italic": true },
      "generic_inserted": { "color": "#b8bb26" },
      "generic_strong": { "color": "#fb4934", "bold": true },
      "generic_subheading": { "color": "#fabd2f" },
      "background": { "background_color": "#282828" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n→ " },
  "html_block": {},
  "html_span": {}
}
