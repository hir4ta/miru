{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#d8dee9",
    "margin": 2
  },
  "block_quote": {
    "color": "#616e88",
    "italic": true,
    "indent": 1,
    "indent_token": "> "
  },
  "paragraph": {},
  "list": { "color": "#d8dee9", "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#88c0d0", "bold": true },
  "h1": { "prefix": "# " },
  "h2": { "prefix": "## " },
  "h3": { "prefix": "### " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "color": "#616e88", "crossed_out": true },
  "emph": { "color": "#ebcb8b", "italic": true },
  "strong": { "color": "#b48ead", "bold": true },
  "hr": { "color": "#4c566a", "format": "\n──────\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". ", "color": "#81a1c1" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#81a1c1", "underline": true },
  "link_text": { "color": "#b48ead" },
  "image": { "color": "#81a1c1", "underline": true },
  "image_text": { "color": "#b48ead", "format": "Image: {{.text}} →" },
  "code": { "color": "#a3be8c" },
  "code_block": {
    "color": "#a3be8c",
    "margin": 2,
    "chroma": {
      "text": { "color": "#d8dee9" },
      "error": { "color": "#d8dee9", "background_color": "#bf616a" },
      "comment": { "color": "#616e88", "italic": true },
      "comment_preproc": { "color": "#5e81ac" },
      "keyword": { "color": "#81a1c1" },
      "keyword_reserved": { "color": "#81a1c1" },
      "keyword_namespace": { "color": "#81a1c1" },
      "keyword_type": { "color": "#8fbcbb" },
      "operator": { "color": "#81a1c1" },
      "punctuation": { "color": "#d8dee9" },
      "name": { "color": "#88c0d0" },
      "name_builtin": { "color": "#8fbcbb" },
      "name_tag": { "color": "#81a1c1" },
      "name_attribute": { "color": "#8fbcbb" },
      "name_class": { "color": "#8fbcbb" },
      "name_constant": { "color": "#b48ead" },
      "name_decorator": { "color": "#88c0d0" },
      "name_exception": { "color": "#bf616a" },
      "name_function": { "color": "#88c0d0" },
      "literal_number": { "color": "#b48ead" },
      "literal_string": { "color": "#a3be8c" },
      "literal_string_escape": { "color": "#ebcb8b" },
      "generic_deleted": { "color": "#bf616a" },
      "generic_emph": { "color": "#ebcb8b", "italic": true },
      "generic_inserted": { "color": "#a3be8c" },
      "generic_strong": { "color": "#b48ead", "bold": true },
      "generic_subheading": { "color": "#88c0d0" },
      "background": { "background_color": "#2e3440" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n→ " },
  "html_block": {},
  "html_span": {}
}
